# API (Vercel 배포 시 Heroku 서버 URL — 로컬 dev는 vite proxy 사용으로 비워도 됨)
VITE_API_URL=https://your-app.herokuapp.com/api

# Cloudinary 설정
# Cloudinary 대시보드 → Settings → Upload → Upload presets 에서 unsigned preset 생성
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# 포트원 V2 설정 (PG: inicis_v2)
VITE_PORTONE_STORE_ID=your_store_id
VITE_PORTONE_CHANNEL_KEY=your_channel_key
